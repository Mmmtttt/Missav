{
  "protocol_version": "1.0",
  "plugin": {
    "id": "video.missav",
    "name": "Missav",
    "version": "1.0.0",
    "entrypoint": "./ultimate_provider.py:MissavProvider"
  },
  "media_types": ["video"],
  "identity": {
    "content_type": "video",
    "platform_label": "MISSAV",
    "aliases": ["missav"]
  },
  "capabilities": [
    { "key": "playback.sources.build" },
    { "key": "playback.proxy.stream" },
    { "key": "playback.proxy.url" },
    { "key": "transport.http.request" }
  ],
  "configuration": {
    "order": 100,
    "label": "Missav",
    "sections": []
  },
  "packaging": {
    "pyinstaller": {
      "collect_all": ["curl_cffi", "cffi"],
      "pip_requirements": ["curl_cffi>=0.6.0", "cffi>=1.15.0"]
    }
  }
}
